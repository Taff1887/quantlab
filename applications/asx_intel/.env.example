# ============================================================
# ASX Intel — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM Provider ---
# Options: "openai" | "anthropic"
LLM_PROVIDER=openai

# OpenAI key (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-placeholder

# Anthropic key (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-placeholder

# Optional: override model name
# MODEL_NAME=gpt-4o
# MODEL_NAME=claude-opus-4-7

# --- ASX Data Source ---
# Uncomment and fill when you wire in a real ASX data provider.
# See backend/ingestion/asx_client.py for options.
# ASX_API_KEY=your_key_here
# ASX_BASE_URL=https://...

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
